{
  "name": "hai",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "hai": "./dist/bin.js"
  },
  "scripts": {
    "dev": "tsx src/bin.ts",
    "build": "tsc",
    "build:exe": "bun run build.ts",
    "build:exe:all": "bun run build.ts --all",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hai/core": "workspace:*",
    "@hai/dashboard": "workspace:*",
    "@hai/engine": "workspace:*",
    "@mariozechner/pi-coding-agent": "^0.62.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "yaml": "^2.8.3"
  }
}
